{
    "CF_API_TOKEN": "cloudflare_api_token",
    "RECORDS": [
        { "domain": "example.com", "record": "wanip"},
        { "domain": "example.com", "record": "example.com"},
        { "domain": "example.com", "record": "external.example.com"},
        { "domain": "example.com", "record": "proxied-host", "proxied": true}
    ],
    "PROXIED_BY_DEFAULT": false,
    "TIME_TO_NOTIFY": 604800,
    "SENDFROM": "dnsmonitor@example.com",
    "SENDTO": "user@example.com"
}